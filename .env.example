# === PostgreSQL Database Configuration ===
# Параметры подключения к базе данных PostgreSQL
PGHOST=localhost
PGPORT=5432
PGDATABASE=opendoor
PGUSER=opendoor_user
PGPASSWORD=change_me_to_secure_password

# === Novotelecom API Credentials ===
# Учетные данные для API интеркома (видеопоток и открытие двери)
# LOGIN - email или логин в системе Новотелеком
# PASSWORD - пароль в системе Новотелеком
# bearer_token - токен для API открытия двери (выдается в аккаунте)
LOGIN=your_email@example.com
PASSWORD=your_password
bearer_token=your_bearer_token_here

# === Web Service Configuration ===
# Параметры Flask приложения
# WEB_HOST=0.0.0.0 означает слушать на всех интерфейсах (для production с Nginx)
# WEB_HOST=127.0.0.1 означает слушать только локально (для разработки)
WEB_HOST=127.0.0.1
WEB_PORT=8000
# SECRET_KEY - ключ для шифрования сеансов (изменяйте на случайную строку!)
SECRET_KEY=change-this-to-a-random-secret-key-at-least-32-characters-long

# === Intercom Configuration ===
# ID вашего домофона в системе Новотелеком
INTERCOM_ID=3104703
